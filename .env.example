# ─── Database ──────────────────────────────────────────
# Neon PostgreSQL connection string (use POOLED URL for serverless)
DATABASE_URL="postgresql://USER:PASS@HOST-pooler.REGION.aws.neon.tech/dpl_prod?sslmode=require"

# ─── AI Chatbot (Groq) ─────────────────────────────────
# Required for AI chatbot (falls back to FAQ mode without it)
GROQ_API_KEY=""
# Optional: override default chat model
# CHAT_MODEL="llama-3.3-70b-versatile"

# ─── Email (Nodemailer SMTP) ───────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@digitalpointllc.com"

# ─── Lead Capture System ───────────────────────────────
# Recipient for audit request notifications (falls back to info@digitalpointllc.com)
ADMIN_EMAIL="info@digitalpointllc.com"

# Admin dashboard credentials (/admin/leads)
ADMIN_USER="admin"
ADMIN_PASS=""  # Set a strong password — never use defaults

# Alpha CRM webhook — base URL only (no trailing slash, no /api/webhook/lead path)
# Lead and ticket forwarding append /api/webhook/leads and /api/webhook/tickets
CRM_WEBHOOK_URL="https://fu-corp-crm.vercel.app"
# Shared secret sent in X-Webhook-Secret header — must match CRM Vercel env
CRM_WEBHOOK_SECRET=""
# HMAC signing key — the request body is signed HMAC-SHA256 and sent in
# X-Webhook-Signature: sha256=<hex> for the CRM to verify authenticity
LEAD_WEBHOOK_SECRET=""

# ─── Rate Limiting (optional — falls back to in-memory) ──
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── SEO ───────────────────────────────────────────────
GOOGLE_SITE_VERIFICATION=""
